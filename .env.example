# ============================================
# Configuration Détection de Fraude - Magasin
# ============================================

# Sources vidéo (séparées par des virgules)
VIDEO_SOURCES=rtsp://camera1:554/stream1

# Mode webcam pour tests (true/false)
WEBCAM_TEST=false

# --- Seuils de détection ---
YOLO_CONFIDENCE=0.45
POSE_CONFIDENCE=0.5
BEHAVIOR_THRESHOLD=0.6

# --- Telegram (optionnel) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Alertes ---
ALERT_SOUND=true
ALERT_COOLDOWN_SECONDS=30
VIDEO_CLIP_DURATION=30

# --- Chemins ---
VIDEO_SAVE_PATH=./recordings
MODEL_PATH=./models
DATABASE_PATH=./data/fraude.db

# --- Dashboard ---
DASHBOARD_PORT=8502

# --- Paramètres métier ---
# Estimation valeur article moyen en DH
VALEUR_ARTICLE_MOYEN_DH=150

# Heures d'ouverture magasin (format HH:MM)
HEURE_OUVERTURE=09:00
HEURE_FERMETURE=22:00

# Rétention des enregistrements en jours
RETENTION_JOURS=30
